# Supabase configuration
# Copy this file to .env and fill in your values
# Get these from your Supabase project: https://supabase.com/dashboard

VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-public-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Anthropic — set as a Supabase Edge Function secret:
#   supabase secrets set ANTHROPIC_API_KEY=your-key
# Get your key at: https://console.anthropic.com/settings/keys

# ANTHROPIC_API_KEY="your-anthropic-api-key"

# Greenhouse — set these as Supabase Edge Function secrets:
#   supabase secrets set GREENHOUSE_API_KEY=your-key
#
# GREENHOUSE_API_KEY       — Harvest API key: Greenhouse → Configure → Dev Center → API Credential Management
# GREENHOUSE_USER_ID       — Your Greenhouse user ID (used as the actor for reject/progress actions)
#
# Rejection reason IDs are unique to your Greenhouse instance.
# Find them at: Greenhouse → Configure → Custom Options → Rejection Reasons
# Click a reason to edit — the numeric ID appears in the URL.
# GH_REJECTION_REASON_ID_STANDARD — for geo, skills, repeat, and unknown-location rejections
# GH_REJECTION_REASON_ID_SPAM     — for fake/spam applications
#
# Rejection email template: Greenhouse → Configure → Email Templates → click template → ID in URL
# GH_REJECTION_EMAIL_TEMPLATE_ID  — email sent to rejected candidates (tip: schedule 2+ days out)

# GREENHOUSE_API_KEY="your-greenhouse-harvest-api-key"
# GREENHOUSE_USER_ID="your-greenhouse-user-id"
# GH_REJECTION_REASON_ID_STANDARD="0"
# GH_REJECTION_REASON_ID_SPAM="0"
# GH_REJECTION_EMAIL_TEMPLATE_ID="0"
